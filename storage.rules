rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Chat images — any authenticated user can upload/read
    match /chat_images/{chatId}/{fileName} {
      allow read, write: if request.auth != null;
    }

    // Expert profile images — only the expert owner can upload, anyone can read
    match /expert_images/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Fallback — any authenticated user can read/write anything else
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
